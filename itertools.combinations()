from itertools import combinations

# 1. Read input and split into string S and integer k
s, k = input().split()
k = int(k)

# 2. Sort the string alphabetically to ensure combinations are generated in order
s = sorted(s)

# 3. Loop through each size from 1 to k
for i in range(1, k + 1):
    # 4. Generate and print combinations for the current size
    for combo in combinations(s, i):
        print("".join(combo))
