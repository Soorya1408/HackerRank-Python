if __name__ == '__main__':
    k = int(input())
    room_list = list(map(int, input().split()))
    
    # Create a set of unique rooms
    room_set = set(room_list)
    
    # The Math Trick:
    # 1. Multiply the sum of unique rooms by K (as if everyone had a full group)
    # 2. Subtract the actual sum of the room list
    # 3. Divide by (K - 1) to find the single room that was "missing" its group members
    captain_room = (sum(room_set) * k - sum(room_list)) // (k - 1)
    
    print(captain_room)
