from itertools import combinations_with_replacement

# 1. Read input and split into string S and integer k
s, k = input().split()
k = int(k)

# 2. Sort the string to ensure the output is in alphabetical order
s_sorted = sorted(s)

# 3. Generate combinations with replacement of length k
result = combinations_with_replacement(s_sorted, k)

# 4. Join the characters of each tuple and print on a new line
for combo in result:
    print("".join(combo))
