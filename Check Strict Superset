if __name__ == '__main__':
    # 1. Read the main set A
    set_a = set(map(int, input().split()))
    
    # 2. Read the number of other sets
    n = int(input())
    
    is_strict_superset = True
    
    for _ in range(n):
        # 3. Read the next set to compare
        other_set = set(map(int, input().split()))
        
        # 4. Check if A is a strict superset
        # A > other_set checks if A contains all elements of other_set
        # AND if A is larger than other_set
        if not (set_a > other_set):
            is_strict_superset = False
            break
            
    print(is_strict_superset)
